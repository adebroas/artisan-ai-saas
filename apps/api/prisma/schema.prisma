generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  operator
  viewer
}

enum CallStatus {
  initiated
  in_progress
  completed
  failed
  abandoned
  transferred
}

enum UrgencyLevel {
  none
  low
  medium
  high
  critical
}

enum CallOutcome {
  message_taken
  appointment_created
  transferred
  callback_requested
  spam
  no_outcome
  out_of_scope
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

enum AppointmentSource {
  ai_agent
  manual
  calendar_sync
}

enum IntegrationType {
  google_calendar
  outlook_calendar
  email_smtp
  webhook_crm
  twilio
  telnyx
  deepgram
  elevenlabs
}

enum IntegrationStatus {
  active
  inactive
  error
  pending_auth
}

enum Speaker {
  assistant
  caller
}

enum BusinessTrade {
  plumber
  heating_engineer
  electrician
  locksmith
  roofer
  painter
  carpenter
  tiler
  mason
  general
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  config_change
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(viewer)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs    AuditLog[]

  @@map("users")
}

model Business {
  id               String        @id @default(cuid())
  name             String
  trade            BusinessTrade
  siret            String?       @unique
  email            String?
  phone            String?
  address          String?
  city             String?
  postalCode       String?
  country          String        @default("FR")
  timezone         String        @default("Europe/Paris")
  locale           String        @default("fr")
  interventionZone String?
  welcomeMessage   String?       @db.Text
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  phoneNumbers     BusinessPhoneNumber[]
  businessRules    BusinessRule?
  calls            CallSession[]
  customers        Customer[]
  appointments     Appointment[]
  integrations     Integration[]
  auditLogs        AuditLog[]

  @@map("businesses")
}

model BusinessPhoneNumber {
  id          String   @id @default(cuid())
  businessId  String
  number      String
  label       String?
  isActive    Boolean  @default(true)
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_phone_numbers")
}

model BusinessRule {
  id                    String   @id @default(cuid())
  businessId            String   @unique
  openingHours          Json     @default("{}")
  supportedRequestTypes Json     @default("[]")
  urgencyRules          Json     @default("[]")
  requiredFields        Json     @default("[]")
  transferRules         Json     @default("{}")
  appointmentRules      Json     @default("{}")
  callFilterRules       Json     @default("{}")
  closingMessage        String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_rules")
}

model CallSession {
  id              String       @id @default(cuid())
  businessId      String
  customerId      String?
  callerNumber    String
  calledNumber    String?
  externalCallId  String?      @unique
  startedAt       DateTime     @default(now())
  endedAt         DateTime?
  durationSeconds Int?
  status          CallStatus   @default(initiated)
  urgencyLevel    UrgencyLevel @default(none)
  outcome         CallOutcome?
  recordingUrl    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  business        Business     @relation(fields: [businessId], references: [id])
  customer        Customer?    @relation(fields: [customerId], references: [id])
  messages        CallMessage[]
  extractedData   CallExtractedData?
  summary         CallSummary?
  appointments    Appointment[]

  @@index([businessId])
  @@index([callerNumber])
  @@index([status])
  @@index([urgencyLevel])
  @@index([startedAt])
  @@map("call_sessions")
}

model CallMessage {
  id            String   @id @default(cuid())
  callSessionId String
  speaker       Speaker
  text          String   @db.Text
  confidence    Float?
  source        String?
  offsetMs      Int?
  createdAt     DateTime @default(now())

  callSession   CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)

  @@index([callSessionId])
  @@map("call_messages")
}

model CallExtractedData {
  id                 String       @id @default(cuid())
  callSessionId      String       @unique
  callerFirstName    String?
  callerLastName     String?
  callerPhone        String?
  callerAddress      String?
  problemDescription String?      @db.Text
  urgencyLevel       UrgencyLevel @default(none)
  desiredSlot        DateTime?
  confirmedSlot      DateTime?
  detectedIntent     String?
  customerType       String?
  additionalData     Json         @default("{}")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  callSession        CallSession  @relation(fields: [callSessionId], references: [id], onDelete: Cascade)

  @@map("call_extracted_data")
}

model CallSummary {
  id                String      @id @default(cuid())
  callSessionId     String      @unique
  shortSummary      String      @db.Text
  structuredSummary Json        @default("{}")
  recommendedAction String?
  tags              String[]    @default([])
  outcome           CallOutcome?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  callSession       CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)

  @@map("call_summaries")
}

model Customer {
  id            String   @id @default(cuid())
  businessId    String
  phone         String
  firstName     String?
  lastName      String?
  email         String?
  address       String?
  city          String?
  postalCode    String?
  notes         String?  @db.Text
  lastContactAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business      @relation(fields: [businessId], references: [id])
  calls         CallSession[]
  appointments  Appointment[]

  @@unique([businessId, phone])
  @@index([businessId])
  @@map("customers")
}

model Appointment {
  id              String            @id @default(cuid())
  businessId      String
  callSessionId   String?
  customerId      String?
  title           String
  description     String?           @db.Text
  startAt         DateTime
  endAt           DateTime
  status          AppointmentStatus @default(pending)
  source          AppointmentSource @default(ai_agent)
  externalEventId String?
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  business        Business          @relation(fields: [businessId], references: [id])
  callSession     CallSession?      @relation(fields: [callSessionId], references: [id])
  customer        Customer?         @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([startAt])
  @@index([status])
  @@map("appointments")
}

model Integration {
  id           String            @id @default(cuid())
  businessId   String
  type         IntegrationType
  status       IntegrationStatus @default(inactive)
  label        String?
  config       Json              @default("{}")
  lastSyncAt   DateTime?
  lastErrorAt  DateTime?
  lastError    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  business     Business          @relation(fields: [businessId], references: [id])

  @@unique([businessId, type])
  @@map("integrations")
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  businessId   String?
  action       AuditAction
  entity       String
  entityId     String?
  before       Json?
  after        Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  business     Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([businessId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}